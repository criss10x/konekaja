# Crypto Exchange Bali — server config (LiteSpeed / Apache)

RewriteEngine On

# Canonical host: www -> non-www (301)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# /index.html -> / (avoid duplicate of the homepage)
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [L,R=301]

# /path/index.html -> /path/
RewriteCond %{THE_REQUEST} \s/+(.+/)index\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# Directory URLs without a trailing slash -> with one
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [L,R=301]

<IfModule mod_headers.c>
  # HTML: revalidate every time so content edits go live immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Fingerprint-free static assets: cache hard, they change rarely
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
